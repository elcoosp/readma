{
  "workspace": [
    "./core",
    "./cli"
  ],
  "tasks": {
    /** Generate readme */
    "r": "deno run -A scripts/gen-readme.ts",
    /** Generate readme watching */
    "r:w": "deno run -A --watch scripts/gen-readme.ts",
    /** Changelog */
    "c": "cog changelog",
    /** Format */
    "f": "cog changelog"
  },
  "imports": {
    "@deno/gfm": "jsr:@deno/gfm@^0.8.2",
    "@std/assert": "jsr:@std/assert@1"
  },
  "fmt": {
    "exclude": [
      "README.md"
    ]
  }
}
